# ── ОБОВ'ЯЗКОВІ ─────────────────────────────────

TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL=@your_channel_here

# Google Gemini (безкоштовно: aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_key_here

# ── РЕКОМЕНДОВАНІ ────────────────────────────────

# Etherscan — кити ETH/USDT/USDC/WETH
# etherscan.io/register → API Keys (безкоштовно)
ETHERSCAN_KEY=your_etherscan_key_here

# Helius — кити Solana (замінює мертвий Solscan)
# helius.dev → Sign Up → API Keys (безкоштовно, 100k req/міс)
HELIUS_KEY=
